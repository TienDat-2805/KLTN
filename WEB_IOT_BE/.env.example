# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed origins (e.g. http://localhost:5173)
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174

# Database
# DATABASE_URL: main connection string (can be Supabase pooler/pgbouncer)
# DIRECT_URL: direct connection string (recommended for migrations when using pooler)
# Examples (replace <...>):
# DATABASE_URL=postgresql://postgres:<password>@<pooler-host>:6543/postgres?pgbouncer=true&schema=public
# DIRECT_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?schema=public
DATABASE_URL=
DIRECT_URL=

# Auth (JWT)
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=7d

# Devices
# Seconds without telemetry before considering a device OFFLINE
DEVICE_OFFLINE_AFTER_SECONDS=60

# How often to check for stale devices
DEVICE_OFFLINE_CHECK_INTERVAL_SECONDS=30

# Command ACK timeout for actuator commands
DEVICE_COMMAND_ACK_TIMEOUT_MS=5000

# MQTT (optional)
# If MQTT_URL is empty, MQTT ingestion is disabled.
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic pattern for telemetry. Default expects messages at: iot/devices/<device_uid>/telemetry
MQTT_TELEMETRY_TOPIC=iot/devices/+/telemetry

# Device Simulator (publishes MQTT telemetry)
# Comma-separated device_uids (must match Device.device_uid in DB)
SIM_DEVICE_UIDS=TEMP_ETH_001,HUMIDITY_ETH_001,LIGHT_ETH_001,CAMERA_ETH_001,AC_ETH_001,POWER_ETH_001

# Publish interval
SIM_INTERVAL_MS=5000

# Probability [0..1] that a message is abnormal (produces WARNING)
SIM_ANOMALY_RATE=0.05

# LPWAN simulator
LPWAN_DEV_EUIS=70B3D57ED005A001
LPWAN_GATEWAY_ID=GW-HANOI-01
LPWAN_INTERVAL_MS=5000

# Keep false for normal demo. Set true only when you want occasional LPWAN alerts.
LPWAN_DEMO_ALERTS=false
LPWAN_ALERT_RATE=0.08

# Set true to demo duplicate/replay uplink detection.
LPWAN_DEMO_COUNTER_ANOMALIES=false
LPWAN_COUNTER_ANOMALY_RATE=0.03
