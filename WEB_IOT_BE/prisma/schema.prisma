generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  WARNING
}

enum ConnectionType {
  WIFI
  WIRED
  LPWAN
}

enum NetworkType {
  LORAWAN
  NB_IOT
  LTE_M
}

enum DeviceJoinStatus {
  UNCLAIMED
  CLAIMED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  fullName     String?  @map("full_name")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  devices Device[]

  @@map("users")
}

model Device {
  id             String  @id @default(uuid()) @db.Uuid
  deviceUid      String  @unique @map("device_uid")
  activationCode String  @unique @map("activation_code")
  userId         String? @db.Uuid @map("user_id")

  // Basic metadata
  type  String @default("sensor")
  model String @default("LPWAN-X1")
  name  String @default("")

  // Connection/network metadata
  connectionType ConnectionType   @default(WIFI) @map("connection_type")
  networkType    NetworkType?     @map("network_type")
  joinStatus     DeviceJoinStatus @default(UNCLAIMED) @map("join_status")

  // LoRaWAN-like identifiers and latest radio metadata
  devEui              String?   @unique @map("dev_eui")
  gatewayId           String?   @map("gateway_id")
  lastJoinAt          DateTime? @map("last_join_at")
  lastRssi            Float?    @map("last_rssi")
  lastSnr             Float?    @map("last_snr")
  lastSpreadingFactor Int?      @map("last_spreading_factor")
  lastBatteryPct      Float?    @map("last_battery_pct")
  lastUplinkCounter   Int?      @map("last_uplink_counter")

  // Optional runtime state
  lightOn        Boolean? @map("light_on")
  acOn           Boolean? @map("ac_on")
  acTargetTempC  Int?     @map("ac_target_temp_c")
  cameraFrameUrl String?  @map("camera_frame_url")

  status     DeviceStatus @default(OFFLINE)
  lastSeenAt DateTime?    @map("last_seen_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  telemetry Telemetry[]

  @@index([userId])
  @@index([connectionType])
  @@index([networkType])
  @@index([joinStatus])
  @@map("devices")
}

model Telemetry {
  id           String   @id @default(uuid()) @db.Uuid
  deviceId     String   @db.Uuid @map("device_id")
  ts           DateTime @map("ts")
  temperatureC Float    @map("temperature_c")
  humidityPct  Float    @map("humidity_pct")
  signalDbm    Float?   @map("signal_dbm")

  // LoRaWAN-like uplink metadata
  rssi            Float? @map("rssi")
  snr             Float? @map("snr")
  spreadingFactor Int?   @map("spreading_factor")
  batteryPct      Float? @map("battery_pct")
  uplinkCounter   Int?   @map("uplink_counter")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, ts])
  @@map("telemetry")
}