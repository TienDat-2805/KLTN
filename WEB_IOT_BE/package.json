{
  "name": "web_iot_be",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "prisma:local": "node scripts/prisma-local-env.js",
    "db:push:local": "npm run prisma:local -- db push",
    "db:seed:local": "npm run prisma:local -- db seed",
    "prisma:studio:local": "npm run prisma:local -- studio",
    "sim:mqtt": "tsx src/simulator/mqttSimulator.ts",
    "sim:lpwan": "tsx src/simulator/lpwanSimulator.ts",
    "sim:all": "concurrently -n mqtt,lpwan -c cyan,magenta \"npm:sim:mqtt\" \"npm:sim:lpwan\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mqtt": "^5.15.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "prisma": "6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
